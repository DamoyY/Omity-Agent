{
  "name": "omity-agent",
  "module": "src/cli.ts",
  "type": "module",
  "private": true,
  "bin": {
    "omity": "src/cli.ts"
  },
  "oclif": {
    "bin": "omity",
    "dirname": "omity-agent",
    "commands": "./src/commands",
    "topicSeparator": " ",
