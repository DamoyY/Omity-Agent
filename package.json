{
  "name": "omity-agent",
  "module": "src/cli.ts",
  "type": "module",
  "private": true,
  "bin": {
    "agent": "src/cli.ts"
  },
  "oclif": {
    "bin": "agent",
    "dirname": "omity-agent",
    "commands": "./src/commands",
    "topicSeparator": " ",
    "topics": {
      "host": {
        "description": "管理 Host 会话"
      },
      "client": {
        "description": "向 Host 发送消息或控制指令"
      }
    }
  },
  "scripts": {
    "agent": "bun src/cli.ts",
    "start": "bun src/cli.ts",
    "test": "bun test",
    "check": "tsc --noEmit && eslint"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/bun": "latest",
    "eslint": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest"
  },
  "dependencies": {
    "@langchain/core": "latest",
    "@langchain/langgraph": "latest",
    "@langchain/langgraph-checkpoint": "latest",
    "@langchain/mcp-adapters": "latest",
    "@langchain/openai": "latest",
    "@modelcontextprotocol/sdk": "latest",
    "@oclif/core": "latest",
    "js-tiktoken": "latest",
    "langchain": "latest",
    "yaml": "latest",
    "zod": "latest"
  }
}
