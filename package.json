      "host": {
        "description": "管理 Host 会话"
      },
      "client": {
        "description": "向 Host 发送消息或控制指令"
      },
      "app": {
        "description": "启动本地 WebUI"
      }
    }
  },
  "scripts": {
    "omity": "bun src/cli.ts",
    "test": "bun test",
